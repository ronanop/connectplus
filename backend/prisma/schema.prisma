model HierarchyTask {
  id             Int                   @id @default(autoincrement())
  organizationId Int                   @map("organization_id")
  title          String
  description    String?
  priority       HierarchyTaskPriority
  status         HierarchyTaskStatus   @default(PENDING)
  deadline       DateTime
  assignedById   Int                   @map("assigned_by_id")
  department     String?
  assignmentMode          HierarchyTaskAssignmentMode @default(DIRECT) @map("assignment_mode")
  /// CRM department when assignmentMode is DEPARTMENT_HANDOFF (managers add teammates in this dept).
  handoffTargetDepartment String?                     @map("handoff_target_department")
  completionRequestedById Int?                  @map("completion_requested_by_id")
  completionRequestedAt   DateTime?             @map("completion_requested_at")
  completionArtifactId    Int?                  @unique @map("completion_artifact_id")
  createdAt      DateTime              @default(now()) @map("created_at")
  updatedAt      DateTime              @updatedAt @map("updated_at")

  organization Organization             @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  assignedBy   User                     @relation("HierarchyTaskAssigner", fields: [assignedById], references: [id], onDelete: Restrict)
  completionRequestedBy User?           @relation("HierarchyTaskCompletionRequester", fields: [completionRequestedById], references: [id], onDelete: SetNull)
  completionArtifact   HierarchyTaskArtifact? @relation("CompletionArtifact", fields: [completionArtifactId], references: [id], onDelete: SetNull)
  assignees    HierarchyTaskAssignee[]
  artifacts    HierarchyTaskArtifact[] @relation("TaskArtifacts")
  comments     HierarchyTaskComment[]
  activities   HierarchyTaskActivity[]

  @@index([organizationId])
  @@index([assignedById])
  @@map("hierarchy_tasks")
}

