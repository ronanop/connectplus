  clientName     String?               @map("client_name")
  sponsorUserId  Int?                  @map("sponsor_user_id")
  tentativeCompletionDate DateTime?    @map("tentative_completion_date") @db.Date
  status         PortfolioProjectStatus @default(PLANNED)
  disciplines    PortfolioDiscipline[] @default([])
  createdById    Int                   @map("created_by_id")
  createdAt      DateTime              @default(now()) @map("created_at")
  updatedAt      DateTime              @updatedAt @map("updated_at")

  organization Organization             @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdBy    User                     @relation("PortfolioProjectCreator", fields: [createdById], references: [id], onDelete: Restrict)
  sponsor      User?                    @relation("PortfolioProjectSponsor", fields: [sponsorUserId], references: [id], onDelete: SetNull)
  members      PortfolioProjectMember[]
  artifacts    PortfolioProjectArtifact[]
  activities   PortfolioProjectActivity[]
  journalEntries PortfolioProjectJournalEntry[]

  @@index([organizationId, status])
  @@index([organizationId, kind])
  @@index([organizationId, updatedAt])
  @@map("portfolio_projects")
}

model PortfolioProjectMember {
  id        Int                 @id @default(autoincrement())
  projectId Int                 @map("project_id")
  userId    Int                 @map("user_id")
  role      PortfolioMemberRole
  createdAt DateTime            @default(now()) @map("created_at")

  project PortfolioProject @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user    User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([projectId, userId])
  @@index([userId])
  @@map("portfolio_project_members")
}

model PortfolioProjectArtifact {
  id             Int      @id @default(autoincrement())
  projectId      Int      @map("project_id")
  journalEntryId Int?     @map("journal_entry_id")
  uploadedById   Int      @map("uploaded_by_id")
  kind           String   @db.VarChar(32)
  fileName       String   @map("file_name")
  storedPath     String   @map("stored_path")
  mimeType       String   @map("mime_type")
  sizeBytes      Int      @map("size_bytes")
  note           String?
  createdAt      DateTime @default(now()) @map("created_at")

  project      PortfolioProject             @relation(fields: [projectId], references: [id], onDelete: Cascade)
  journalEntry PortfolioProjectJournalEntry? @relation(fields: [journalEntryId], references: [id], onDelete: Cascade)
  uploadedBy   User                         @relation("PortfolioProjectArtifactUploader", fields: [uploadedById], references: [id], onDelete: Restrict)

  @@index([projectId])
  @@index([journalEntryId])
  @@map("portfolio_project_artifacts")
}

model PortfolioProjectJournalEntry {
  id        Int                      @id @default(autoincrement())
  projectId Int                      @map("project_id")
  userId    Int                      @map("user_id")
  entryType PortfolioJournalEntryType @map("entry_type")
  body      String                   @db.Text
  createdAt DateTime                 @default(now()) @map("created_at")

  project   PortfolioProject           @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user      User                       @relation(fields: [userId], references: [id], onDelete: Cascade)
  artifacts PortfolioProjectArtifact[]

  @@index([projectId, createdAt])
  @@map("portfolio_project_journal_entries")
}

model PortfolioProjectActivity {
  id        Int      @id @default(autoincrement())
  projectId Int      @map("project_id")
  userId    Int      @map("user_id")
  action    String
  meta      Json?
  createdAt DateTime @default(now()) @map("created_at")

  project PortfolioProject @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user    User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@map("portfolio_project_activities")
}

model ApprovalConfig {
  id             Int      @id @default(autoincrement())
  hwMarginMinPct Decimal  @map("hw_margin_min_pct")
  swMarginMinPct Decimal  @map("sw_margin_min_pct")
  svcMarginMinPct Decimal @map("svc_margin_min_pct")

  @@map("approval_config")
}

model RevenueTarget {
  id        Int      @id @default(autoincrement())
  year      Int
  month     Int
  target    Decimal

  @@map("revenue_targets")
  @@unique([year, month])
}

model NotificationPreference {
  id        Int      @id @default(autoincrement())
  userId    Int?     @map("user_id")
  roleId    Int?     @map("role_id")
  triggerKey String  @map("trigger_key")
  channels  Json     @map("channels_json")

  user      User?    @relation(fields: [userId], references: [id])
  role      Role?    @relation(fields: [roleId], references: [id])

  @@map("notification_preferences")
}

model DashboardPreference {
  id        Int      @id @default(autoincrement())
  userId    Int      @map("user_id") @unique
  config    Json     @map("config_json")
  updatedAt DateTime @updatedAt @map("updated_at")

  user      User     @relation(fields: [userId], references: [id])

  @@map("dashboard_preferences")
}

model Product {
  id          Int      @id @default(autoincrement())
  name        String
  category    String
  unit        String
  defaultPrice Decimal @map("default_price")

  @@map("products")
}

model Distributor {
  id          Int      @id @default(autoincrement())
  name        String
  contact     String?
  leadTimeDays Int?    @map("lead_time_days")
  territory   String?

  @@map("distributors")
}

model Industry {
  id    Int    @id @default(autoincrement())
  name  String @unique

  @@map("industries")
}

model LeadSource {
  id    Int    @id @default(autoincrement())
  name  String @unique

  @@map("lead_sources")
}

model LossReason {
  id    Int    @id @default(autoincrement())
  name  String @unique

  @@map("loss_reasons")
}

model Department {
  id    Int    @id @default(autoincrement())
  name  String @unique

  @@map("departments")
}

model SkillTag {
  id    Int    @id @default(autoincrement())
  name  String @unique

  @@map("skill_tags")
}

model ApiFetchSession {
  id         Int      @id @default(autoincrement())
  userId     Int      @map("user_id")
  name       String
  url        String
  method     String
  headers    Json     @map("headers_json")
  response   Json     @map("response_json")
  createdAt  DateTime @default(now()) @map("created_at")

  user       User     @relation(fields: [userId], references: [id])

  @@map("api_fetch_sessions")
  @@index([userId])
}

model PresalesProject {
  id                String             @id @default(cuid())
  leadId            String?
  convertedOpportunityId Int?          @map("converted_opportunity_id")
  title             String
  clientName        String
  assignedTo        String
  assignedBy        String
  currentStage      PresalesStage      @default(INITIATED)
  priority          Priority           @default(MEDIUM)
  estimatedValue    Float?
  expectedCloseDate DateTime?
  handoffSummary    String?            @map("handoff_summary")
  winProbability    Float              @default(0)
  status            String             @default("active")
  lostReason        String?
  notes             String?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt

  convertedOpportunity Opportunity?     @relation(fields: [convertedOpportunityId], references: [id])
  stages       PresalesStageLog[]
  boq          BOQ?
  poc          POC?
  proposal     Proposal?
  requirements RequirementDoc?
  solution     SolutionDesign?
  activities   PresalesActivity[]
}

model PresalesStageLog {
  id               String          @id @default(cuid())
  projectId        String
  stage            PresalesStage
  completedAt      DateTime        @default(now())
  completedBy      String
  notes            String?
  timeTakenMinutes Int?

  project PresalesProject @relation(fields: [projectId], references: [id])

  @@index([projectId])
}

model RequirementDoc {
  id            String          @id @default(cuid())
  projectId     String          @unique
  rawNotes      String?
  functionalReq Json?
  technicalReq  Json?
  scopeSplit    Json?           @map("scope_split_json")
  timelineNotes String?         @map("timeline_notes")
  complianceSecurity String?    @map("compliance_security")
  handoffNotes  String?         @map("handoff_notes")
  constraints   String?
  stakeholders  Json?
  completedAt   DateTime?

  project PresalesProject @relation(fields: [projectId], references: [id])
}

model SolutionDesign {
  id              String          @id @default(cuid())
  projectId       String          @unique
  architectureUrl String?
  diagramUrl      String?
  techStack       Json?
  systemDesignSummary String?    @map("system_design_summary")
  deploymentTopology String?     @map("deployment_topology")
  infraComponents Json?          @map("infra_components_json")
  finalizedStack  Json?          @map("finalized_stack_json")
  competitors     Json?
  recommendedOption String?
  justification   String?
  completedAt     DateTime?

  project PresalesProject @relation(fields: [projectId], references: [id])
}

model BOQ {
  id            String          @id @default(cuid())
  projectId     String          @unique
  lineItems     Json
  totalValue    Float?
  oemName       String?
  validity      DateTime?
  attachmentUrl String?
  effortDays    Int?
  resourceCount Int?
  status        String          @default("draft")
  version       Int             @default(1)
  completedAt   DateTime?

  project PresalesProject @relation(fields: [projectId], references: [id])
}

model POC {
  id              String          @id @default(cuid())
  projectId       String          @unique
  objective       String?
  scope           String?
  successCriteria Json?
  environment     String?
  assignedEngineer String?
  startDate       DateTime?
  endDate         DateTime?
  outcome         String?
  findings        String?
  evidenceUrls    Json?
  status          String          @default("planned")
  gatingStatus    String?         @map("gating_status")
  waiverReason    String?         @map("waiver_reason")

  project PresalesProject @relation(fields: [projectId], references: [id])
}

model Proposal {
  id               String          @id @default(cuid())
  projectId        String          @unique
  executiveSummary String?
  scopeOfWork      String?
  technicalApproach String?
  commercials      Json?
  timeline         Json?
  teamStructure    Json?
  proposalSummary  String?        @map("proposal_summary")
  termsConditions  String?
  pdfUrl           String?
  version          Int             @default(1)
  status           String          @default("draft")
  sentAt           DateTime?
  clientFeedback   String?
  closureSupportNotes String?     @map("closure_support_notes")
  readyForSalesAt  DateTime?      @map("ready_for_sales_at")
  completedAt      DateTime?

  project PresalesProject @relation(fields: [projectId], references: [id])
}

model PresalesActivity {
  id          String          @id @default(cuid())
  projectId   String
  type        String
  description String
  createdBy   String
  fileUrl     String?
  createdAt   DateTime        @default(now())

  project PresalesProject @relation(fields: [projectId], references: [id])

  @@index([projectId])
}

/// Org unit for HR (distinct from CRM `User.department` string).
model HrDepartment {
  id             Int      @id @default(autoincrement())
  organizationId Int      @map("organization_id")
  name           String
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  employees    HrEmployee[]

  @@index([organizationId])
  @@map("hr_departments")
}

model HrEmployee {
  id             Int      @id @default(autoincrement())
  organizationId Int      @map("organization_id")
  hrDepartmentId Int?     @map("hr_department_id")
  userId         Int?     @unique @map("user_id")
  firstName      String   @map("first_name")
  lastName       String   @map("last_name")
  email          String
  employeeCode   String?  @map("employee_code")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  hrDepartment HrDepartment? @relation(fields: [hrDepartmentId], references: [id], onDelete: SetNull)
  user         User?         @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@unique([organizationId, email])
  @@index([organizationId])
  @@index([hrDepartmentId])
  @@map("hr_employees")
}
