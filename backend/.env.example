# Copy to .env and fill in real values (never commit .env).
# PostgreSQL connection string used by Prisma.
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public
DATABASE_URL="postgresql://postgres:password@localhost:5432/crm_db?schema=public"

# API server
PORT=4000
NODE_ENV=development

# JWT signing secret — use a long random string; keep identical across restarts in dev.
JWT_SECRET="change-me-to-a-long-random-string"

# CRM session: single long-lived JWT + httpOnly cookie (same lifetime). Logout clears the cookie.
# Default when unset: 30d. Examples: 8h, 7d, 30d, 90d
# JWT_EXPIRES_IN=30d

# Microsoft Graph / Azure AD app (mail, SSO, inbox) — optional until you use those features
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
# PKCE / SPA sign-in: leave secret unset and do not set AZURE_USE_CLIENT_SECRET (public client token exchange).
# Confidential "Web" app only:
# AZURE_CLIENT_SECRET=
# AZURE_USE_CLIENT_SECRET=true
#
# Microsoft SSO — first-time users (JIT provisioning)
# Anyone who completes SSO in your Entra tenant gets a CRM user automatically (default role USER).
# Security: authorize URL must use your tenant id (single-tenant); token `tid` is checked against AZURE_TENANT_ID.
# AZURE_SSO_DISABLE_JIT=true          # set to require pre-created CRM users only (old behavior)
# AZURE_SSO_ALLOWED_EMAIL_DOMAINS=    # optional: contoso.com,fabrikam.com — restrict new JIT users by email domain
# AZURE_SSO_JIT_ROLE=USER             # role name (must exist in DB)
# AZURE_SSO_JIT_ORG_CODE=             # optional: organizations.code for SSO new users not @*.cachedigitech.com
# (Emails on cachedigitech.com / *.cachedigitech.com always use organization code cachedigitech-internal.)
AZURE_FROM_EMAIL=

# URLs used in invitation / notification emails (optional)
# APP_BASE_URL=http://localhost:3000
# APP_LOGIN_URL=http://localhost:3000/login

# Attendance geo verification token lifetime (ms), default 20 minutes. Range 60000–3600000.
# GEO_VERIFICATION_TTL_MS=1200000

# HRMS or other integrations (optional)
# HRMS_API_KEY=
