# Copy to .env and fill in real values (never commit .env).
# PostgreSQL connection string used by Prisma.
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public
DATABASE_URL="postgresql://postgres:password@localhost:5432/crm_db?schema=public"

# API server
PORT=4000
NODE_ENV=development

# JWT signing secret — use a long random string; keep identical across restarts in dev.
JWT_SECRET="change-me-to-a-long-random-string"

# Microsoft Graph / Azure AD app (mail, SSO, inbox) — optional until you use those features
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=
AZURE_FROM_EMAIL=

# URLs used in invitation / notification emails (optional)
# APP_BASE_URL=http://localhost:3000
# APP_LOGIN_URL=http://localhost:3000/login

# HRMS or other integrations (optional)
# HRMS_API_KEY=
