# Copy to .env.local or .env (never commit real values).
# Local dev: leave VITE_API_URL empty to use the Vite proxy (/api -> backend).

# Backend origin when not using the dev proxy (e.g. production or mobile testing)
# VITE_API_URL=http://localhost:4000

# Public app URL — must match Azure AD redirect URIs for MS login (HTTPS or localhost)
VITE_PUBLIC_APP_URL=https://localhost:3000

# Same Azure app registration as the backend (public client values only)
VITE_AZURE_TENANT_ID=
VITE_AZURE_CLIENT_ID=
