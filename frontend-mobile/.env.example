# Copy to .env (never commit real values).
# Mobile dev server proxies /api to the backend when VITE_API_URL is unset.

# Set this if the app calls the API directly (no proxy), e.g. device on LAN:
# VITE_API_URL=http://YOUR_LAN_IP:4000

# Origin only — do not add /login (the app appends it for Microsoft SSO).
VITE_PUBLIC_APP_URL=https://localhost:3001

VITE_AZURE_TENANT_ID=
VITE_AZURE_CLIENT_ID=
